<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HxPushApp.MessagesPage"
             Title="消息">

    <Grid RowDefinitions="Auto,*"
          Padding="20,18"
          RowSpacing="14">

        <VerticalStackLayout Spacing="4">
            <Label
                Text="消息列表"
                FontSize="28"
                FontAttributes="Bold" />

            <Label
                Text="{Binding SummaryText}"
                FontSize="14"
                TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
        </VerticalStackLayout>

        <RefreshView
            Grid.Row="1"
            Refreshing="OnRefreshing">
            <CollectionView
                ItemsSource="{Binding Messages}"
                SelectionMode="Single"
                SelectionChanged="OnMessageSelected"
                Scrolled="OnMessagesScrolled">
                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        Padding="0,60"
                        HorizontalOptions="Center"
                        Spacing="8">
                        <Label
                            Text="暂无消息"
                            FontSize="18"
                            HorizontalTextAlignment="Center" />
                        <Label
                            Text="下拉刷新本地消息"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,10"
                            Padding="14"
                            MaximumHeightRequest="112"
                            Stroke="{AppThemeBinding Light=#E4E4E4, Dark=#3A3A3A}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#242424}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>

                            <Grid
                                ColumnDefinitions="*,Auto"
                                RowDefinitions="Auto,Auto"
                                ColumnSpacing="12"
                                RowSpacing="8">
                                <Label
                                    Text="{Binding Msg}"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    MaxLines="2"
                                    LineBreakMode="TailTruncation" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding ID, StringFormat='#{0}'}"
                                    FontSize="13"
                                    TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}" />

                                <HorizontalStackLayout
                                    Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Spacing="8">
                                    <Label
                                        Text="设备"
                                        FontSize="13"
                                        BackgroundColor="AntiqueWhite"
                                        TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}" />

                                    <Label
                                        Text="{Binding Hwid}"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light=#444444, Dark=#DDDDDD}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <Grid
                        HeightRequest="44"
                        IsVisible="{Binding IsLoadingMore}">
                        <ActivityIndicator
                            IsRunning="{Binding IsLoadingMore}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Grid>
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>

        <Border
            x:Name="NoMoreDataToast"
            Grid.RowSpan="2"
            Margin="0,0,0,24"
            Padding="16,10"
            IsVisible="False"
            Opacity="0"
            InputTransparent="True"
            HorizontalOptions="Center"
            VerticalOptions="End"
            StrokeThickness="0"
            BackgroundColor="#CC222222">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Label
                Text="没有新的数据"
                FontSize="14"
                TextColor="White" />
        </Border>
    </Grid>
</ContentPage>
