<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HxPushApp.MessagesPage"
             Title="消息列表"
             Background="{StaticResource PageGradientBrush}">

    <Grid RowDefinitions="Auto,Auto,*"
          Padding="18,16"
          RowSpacing="12">

        <Border
            Padding="18,16"
            StrokeThickness="0"
            Background="{StaticResource PrimaryGradientBrush}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="5">
                    <Label
                        Text="消息中心"
                        FontSize="26"
                        FontAttributes="Bold"
                        TextColor="White" />
                    <Label
                        Text="{Binding SummaryText}"
                        FontSize="13"
                        TextColor="#DBEAFE" />
                    <Border
                        Padding="9,4"
                        HorizontalOptions="Start"
                        StrokeThickness="0"
                        BackgroundColor="#E0F2FE">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label
                            x:Name="WebSocketConnectionStatusLabel"
                            FontSize="12"
                            FontAttributes="Bold" />
                    </Border>
                </VerticalStackLayout>

                <Button
                    x:Name="RefreshMessagesButton"
                    Grid.Column="1"
                    Text="↻"
                    FontSize="24"
                    TextColor="White"
                    BackgroundColor="#FFFFFF33"
                    Padding="0"
                    WidthRequest="46"
                    HeightRequest="46"
                    IsVisible="{OnPlatform WinUI=True, Default=False}"
                    ToolTipProperties.Text="刷新消息"
                    SemanticProperties.Description="刷新消息"
                    Clicked="OnRefreshButtonClicked"
                    VerticalOptions="Center" />
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Padding="14,5"
            Stroke="#CFE0FF"
            StrokeThickness="1"
            BackgroundColor="#FFFFFFCC">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Label
                    Text="设备筛选"
                    FontSize="13"
                    FontAttributes="Bold"
                    VerticalOptions="Center"
                    TextColor="#2563EB" />
                <Picker
                    x:Name="DeviceFilterPicker"
                    Grid.Column="1"
                    Title="选择设备"
                    ItemsSource="{Binding DeviceFilters}"
                    SelectedIndexChanged="OnDeviceFilterChanged" />
            </Grid>
        </Border>

        <RefreshView
            x:Name="MessagesRefreshView"
            Grid.Row="2"
            Refreshing="OnRefreshing">
            <CollectionView
                x:Name="MessagesCollectionView"
                Margin="0,2"
                ItemsSource="{Binding Messages}"
                SelectionMode="Single"
                SelectionChanged="OnMessageSelected"
                Scrolled="OnMessagesScrolled">
                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        Padding="0,72"
                        HorizontalOptions="Center"
                        Spacing="10">
                        <Border
                            Padding="18"
                            StrokeThickness="0"
                            BackgroundColor="#DBEAFE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Label
                                Text="暂无消息"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#1D4ED8"
                                HorizontalTextAlignment="Center" />
                        </Border>
                        <Label
                            Text="下拉可从服务器同步最新消息"
                            FontSize="14"
                            TextColor="#64748B"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,10"
                            Padding="16,14"
                            MaximumHeightRequest="118"
                            Stroke="#D7E6FF"
                            StrokeThickness="1"
                            BackgroundColor="#FFFFFFF2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#1A2563EB" Offset="0,4" Radius="12" Opacity="0.12" />
                            </Border.Shadow>

                            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                <Label
                                    Text="{Binding Msg}"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    TextColor="#172554"
                                    MaxLines="2"
                                    LineBreakMode="TailTruncation" />

                                <Grid
                                    Grid.Row="1"
                                    ColumnDefinitions="Auto,*,Auto"
                                    ColumnSpacing="8">
                                    <Border
                                        Padding="8,3"
                                        StrokeThickness="0"
                                        BackgroundColor="#E0EFFF">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Label
                                            Text="设备"
                                            FontSize="12"
                                            TextColor="#2563EB" />
                                    </Border>

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding Hwid}"
                                        FontSize="13"
                                        LineBreakMode="TailTruncation"
                                        TextColor="#475569" />

                                    <Label
                                        Grid.Column="2"
                                        Text="{Binding MsgDate, Converter={StaticResource UnixTimestampToTimeConverter}}"
                                        FontSize="12"
                                        TextColor="#64748B" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <Grid HeightRequest="52" IsVisible="{Binding IsLoadingMore}">
                        <HorizontalStackLayout
                            Spacing="8"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <ActivityIndicator IsRunning="{Binding IsLoadingMore}" />
                            <Label
                                Text="正在加载更多..."
                                FontSize="13"
                                TextColor="#64748B"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>

        <Border
            x:Name="LatestMessagesNotice"
            Grid.Row="2"
            Margin="0,14"
            Padding="16,9"
            IsVisible="False"
            HorizontalOptions="Center"
            VerticalOptions="Start"
            ZIndex="100"
            StrokeThickness="0"
            Background="{StaticResource PrimaryGradientBrush}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#402563EB" Offset="0,6" Radius="12" Opacity="0.28" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLatestMessagesNoticeTapped" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout Spacing="6">
                <Label Text="有最新消息" FontSize="14" FontAttributes="Bold" TextColor="White" />
                <Label Text="点击查看" FontSize="12" TextColor="#DBEAFE" />
            </HorizontalStackLayout>
        </Border>

        <Border
            x:Name="NoMoreDataToast"
            Grid.RowSpan="3"
            Margin="0,0,0,24"
            Padding="16,10"
            IsVisible="False"
            Opacity="0"
            InputTransparent="True"
            HorizontalOptions="Center"
            VerticalOptions="End"
            StrokeThickness="0"
            BackgroundColor="#0F172ACC">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Label Text="没有更多数据" FontSize="14" TextColor="White" />
        </Border>

        <Border
            Grid.RowSpan="3"
            Padding="18,14"
            IsVisible="{Binding IsServerRequesting}"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            StrokeThickness="0"
            Background="{StaticResource PrimaryGradientBrush}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16" />
            </Border.StrokeShape>
            <HorizontalStackLayout Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsServerRequesting}" Color="White" VerticalOptions="Center" />
                <Label Text="{Binding LoadingText}" FontSize="14" TextColor="White" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentPage>
