<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HxPushApp.MessagesPage"
             Title="消息">

    <Grid RowDefinitions="Auto,Auto,*"
          Padding="20,18"
          RowSpacing="14">

        <Grid
            ColumnDefinitions="*,Auto"
            ColumnSpacing="12">
            <VerticalStackLayout Spacing="4">
                <Label
                    Text="消息列表"
                    FontSize="28"
                    FontAttributes="Bold" />

                <Label
                    Text="{Binding SummaryText}"
                    FontSize="14"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
            </VerticalStackLayout>

            <Button
                x:Name="RefreshMessagesButton"
                Grid.Column="1"
                Text="↻"
                FontSize="24"
                Padding="0"
                WidthRequest="44"
                HeightRequest="44"
                IsVisible="{OnPlatform WinUI=True, Default=False}"
                ToolTipProperties.Text="刷新消息"
                SemanticProperties.Description="刷新消息"
                Clicked="OnRefreshButtonClicked"
                VerticalOptions="Center" />
        </Grid>

        <Grid
            Grid.Row="1"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="10">
            <Label
                Text="设备"
                FontSize="14"
                VerticalOptions="Center"
                TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />

            <Picker
                x:Name="DeviceFilterPicker"
                Grid.Column="1"
                Title="选择设备"
                ItemsSource="{Binding DeviceFilters}"
                SelectedIndexChanged="OnDeviceFilterChanged" />
        </Grid>

        <RefreshView
            x:Name="MessagesRefreshView"
            Grid.Row="2"
            Refreshing="OnRefreshing">
            <CollectionView
                ItemsSource="{Binding Messages}"
                SelectionMode="Single"
                SelectionChanged="OnMessageSelected"
                Scrolled="OnMessagesScrolled">
                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        Padding="0,60"
                        HorizontalOptions="Center"
                        Spacing="8">
                        <Label
                            Text="暂无消息"
                            FontSize="18"
                            HorizontalTextAlignment="Center" />
                        <Label
                            Text="下拉可从服务端同步消息"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,10"
                            Padding="14"
                            MaximumHeightRequest="112"
                            Stroke="{AppThemeBinding Light=#E4E4E4, Dark=#3A3A3A}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#242424}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>

                            <Grid
                                ColumnDefinitions="*"
                                RowDefinitions="Auto,Auto"
                                ColumnSpacing="12"
                                RowSpacing="8">
                                <Label
                                    Text="{Binding Msg}"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    MaxLines="2"
                                    LineBreakMode="TailTruncation" />

                                <Grid
                                    Grid.Row="1"
                                    ColumnDefinitions="Auto,*,Auto"
                                    ColumnSpacing="8">
                                    <Label
                                        Text="设备"
                                        FontSize="13"
                                        BackgroundColor="AntiqueWhite"
                                        TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}" />

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding Hwid}"
                                        FontSize="13"
                                        LineBreakMode="TailTruncation"
                                        TextColor="{AppThemeBinding Light=#444444, Dark=#DDDDDD}" />

                                    <Label
                                        Grid.Column="2"
                                        Text="{Binding MsgDate, Converter={StaticResource UnixTimestampToTimeConverter}}"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <Grid
                        HeightRequest="44"
                        IsVisible="{Binding IsLoadingMore}">
                        <HorizontalStackLayout
                            Spacing="8"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <ActivityIndicator IsRunning="{Binding IsLoadingMore}" />
                            <Label
                                Text="正在加载更多..."
                                FontSize="13"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}" />
                        </HorizontalStackLayout>
                    </Grid>
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>

        <Border
            x:Name="NoMoreDataToast"
            Grid.RowSpan="3"
            Margin="0,0,0,24"
            Padding="16,10"
            IsVisible="False"
            Opacity="0"
            InputTransparent="True"
            HorizontalOptions="Center"
            VerticalOptions="End"
            StrokeThickness="0"
            BackgroundColor="#CC222222">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Label
                Text="没有新的数据"
                FontSize="14"
                TextColor="White" />
        </Border>

        <Border
            Grid.RowSpan="3"
            Padding="18,14"
            IsVisible="{Binding IsServerRequesting}"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            StrokeThickness="0"
            BackgroundColor="#DD222222">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>

            <HorizontalStackLayout Spacing="12">
                <ActivityIndicator
                    IsRunning="{Binding IsServerRequesting}"
                    Color="White"
                    VerticalOptions="Center" />
                <Label
                    Text="{Binding LoadingText}"
                    FontSize="14"
                    TextColor="White"
                    VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentPage>
