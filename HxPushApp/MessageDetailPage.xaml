<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HxPushApp.MessageDetailPage"
             Title="消息详情"
             Background="{StaticResource PageGradientBrush}">

    <ScrollView>
        <VerticalStackLayout Padding="20,20" Spacing="16">
            <VerticalStackLayout Spacing="5">
                <Label Text="消息详情" FontSize="28" FontAttributes="Bold" TextColor="#172554" />
                <Label Text="{Binding MessageNo}" FontSize="13" TextColor="#64748B" />
            </VerticalStackLayout>

            <Border Padding="20" Stroke="#D7E6FF" StrokeThickness="1" BackgroundColor="#FFFFFFE6">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1A2563EB" Offset="0,5" Radius="14" Opacity="0.16" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="设备" FontSize="12" FontAttributes="Bold" TextColor="#2563EB" />
                            <Label Text="{Binding Hwid}" FontSize="16" TextColor="#172554" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="End">
                            <Label Text="时间" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" TextColor="#2563EB" />
                            <Label
                                Text="{Binding MsgDate, Converter={StaticResource UnixTimestampToTimeConverter}}"
                                FontSize="14"
                                HorizontalTextAlignment="End"
                                TextColor="#475569" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#DCE9FF" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="完整内容" FontSize="12" FontAttributes="Bold" TextColor="#2563EB" />
                        <Label
                            Text="{Binding MessageContent}"
                            FontSize="17"
                            LineBreakMode="WordWrap"
                            TextColor="#172554" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
