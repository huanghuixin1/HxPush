<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HxPushApp.MessageDetailPage"
             Title="消息详情">

    <ScrollView>
        <VerticalStackLayout
            Padding="20,18"
            Spacing="18">

            <VerticalStackLayout Spacing="6">
                <Label
                    Text="消息详情"
                    FontSize="28"
                    FontAttributes="Bold" />

                <Label
                    Text="{Binding MessageNo}"
                    FontSize="14"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
            </VerticalStackLayout>

            <Border
                Padding="14"
                Stroke="{AppThemeBinding Light=#E4E4E4, Dark=#3A3A3A}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#242424}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="设备"
                            FontSize="13"
                            TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}" />
                        <Label
                            Text="{Binding Hwid}"
                            FontSize="16" />
                    </VerticalStackLayout>

                    <BoxView
                        HeightRequest="1"
                        Color="{AppThemeBinding Light=#EEEEEE, Dark=#333333}" />

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="完整内容"
                            FontSize="13"
                            TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}" />
                        <Label
                            Text="{Binding Content}"
                            FontSize="17"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
