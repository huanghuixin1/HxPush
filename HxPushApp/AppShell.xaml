<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HxPushApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HxPushApp"
    Title="彗星消息推送"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#172033}"
    Shell.TabBarForegroundColor="#2563EB"
    Shell.TabBarTitleColor="#2563EB"
    Shell.TabBarUnselectedColor="#64748B">

    <TabBar>
        <ShellContent
            Title="消息"
            ContentTemplate="{DataTemplate local:MessagesPage}"
            Route="MessagesPage" />

        <ShellContent
            Title="设置"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
