<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HxPushApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HxPushApp"
    Title="彗星消息推送"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F1F1F}"
    Shell.TabBarForegroundColor="#512BD4"
    Shell.TabBarTitleColor="#512BD4"
    Shell.TabBarUnselectedColor="#777777">

    <TabBar>
        <ShellContent
            Title="首页"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="消息"
            ContentTemplate="{DataTemplate local:MessagesPage}"
            Route="MessagesPage" />

        <ShellContent
            Title="设置"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
