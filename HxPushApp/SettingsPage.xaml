<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HxPushApp.SettingsPage"
             Title="设置">

    <Grid
        Padding="24"
        RowDefinitions="Auto,Auto,Auto,*"
        RowSpacing="16">

        <Label
            Grid.Row="0"
            Text="设置"
            FontSize="28"
            FontAttributes="Bold" />

        <Label
            Grid.Row="1"
            Text="这里放账号、通知开关或应用配置。"
            FontSize="16" />

        <VerticalStackLayout
            Grid.Row="2"
            Spacing="16">

            <VerticalStackLayout Spacing="8">
                <Label
                    Text="AppKey"
                    FontSize="16"
                    FontAttributes="Bold" />

                <Grid
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                    <Entry
                        x:Name="AppKeyEntry"
                        Grid.Column="0"
                        Placeholder="请输入 AppKey"
                        ClearButtonVisibility="WhileEditing"
                        MaxLength="128"
                        ReturnType="Done" />

                    <Button
                        x:Name="SaveAppKeyButton"
                        Grid.Column="1"
                        Text="保存"
                        Clicked="OnSaveAppKeyClicked"
                        VerticalOptions="Fill" />
                </Grid>

                <Label
                    x:Name="AppKeySaveStatusLabel"
                    Text="保存在当前设备，用于区分不同用户。"
                    FontSize="13"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
            </VerticalStackLayout>

            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="10">
                <Button
                    x:Name="WebSocketTestButton"
                    Grid.Column="0"
                    Text="测试连接"
                    Clicked="OnWebSocketTestClicked"
                    HorizontalOptions="Fill" />

                <Button
                    x:Name="WebSocketDisconnectButton"
                    Grid.Column="1"
                    Text="断开连接"
                    IsEnabled="False"
                    Clicked="OnWebSocketDisconnectClicked"
                    HorizontalOptions="Fill" />
            </Grid>

            <Grid ColumnDefinitions="*,110">
                <Editor
                    Grid.Column="0"
                    x:Name="EditTestSendWsMsg"
                    Placeholder="这里填写消息内容"
                    Text="消息内容" />

                <Button
                    Grid.Column="1"
                    x:Name="BtnTestSendWsMsg"
                    Clicked="BtnTestSendWsMsg_Clicked"
                    Text="发送消息" />
            </Grid>
        </VerticalStackLayout>

        <Border
            Grid.Row="3"
            Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"
            StrokeThickness="1"
            Padding="12">

            <ScrollView
                x:Name="WebSocketResultScrollView"
                VerticalScrollBarVisibility="Always">

                <Label
                    x:Name="WebSocketTestResultLabel"
                    Text="尚未测试"
                    FontSize="14"
                    LineBreakMode="WordWrap"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>
