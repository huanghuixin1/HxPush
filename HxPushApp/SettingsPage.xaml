<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HxPushApp.SettingsPage"
             Title="设置">

    <ContentPage.Resources>
        <!-- 连接操作使用高对比蓝色；禁用时改为低饱和灰色，避免和可操作状态混淆。 -->
        <Style x:Key="ConnectActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="BorderColor" Value="#1D4ED8" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HeightRequest" Value="48" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Background" Value="#1D4ED8" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Background" Value="#1E40AF" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="Background" Value="{AppThemeBinding Light=#E2E8F0, Dark=#263449}" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#94A3B8, Dark=#718096}" />
                                <Setter Property="BorderColor" Value="{AppThemeBinding Light=#CBD5E1, Dark=#3D4B60}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <!-- 断开操作仅在可用时显示醒目的危险色，禁用状态与连接按钮保持一致。 -->
        <Style x:Key="DisconnectActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="BorderColor" Value="#B91C1C" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HeightRequest" Value="48" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Background" Value="#B91C1C" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Background" Value="#991B1B" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="Background" Value="{AppThemeBinding Light=#E2E8F0, Dark=#263449}" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#94A3B8, Dark=#718096}" />
                                <Setter Property="BorderColor" Value="{AppThemeBinding Light=#CBD5E1, Dark=#3D4B60}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Grid
        Padding="24"
        RowDefinitions="Auto,Auto,Auto,*"
        RowSpacing="16">

        <Label
            Grid.Row="0"
            Text="设置"
            FontSize="28"
            FontAttributes="Bold" />

        <Label
            Grid.Row="1"
            Text="这里放账号、通知开关或应用配置。"
            FontSize="16" />

        <VerticalStackLayout
            Grid.Row="2"
            Spacing="16">

            <VerticalStackLayout Spacing="8">
                <Label
                    Text="AppKey"
                    FontSize="16"
                    FontAttributes="Bold" />

                <Grid
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                    <Entry
                        x:Name="AppKeyEntry"
                        Grid.Column="0"
                        Placeholder="请输入 AppKey"
                        ClearButtonVisibility="WhileEditing"
                        MaxLength="128"
                        ReturnType="Done"
                        Completed="OnAppKeyEntryCompleted" />

                    <Button
                        x:Name="SaveAppKeyButton"
                        Grid.Column="1"
                        Text="保存"
                        Clicked="OnSaveAppKeyClicked"
                        VerticalOptions="Fill" />
                </Grid>

                <Label
                    x:Name="AppKeySaveStatusLabel"
                    Text="保存在当前设备，用于区分不同用户。"
                    FontSize="13"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label
                    Text="服务器地址"
                    FontSize="16"
                    FontAttributes="Bold" />

                <Picker
                    x:Name="ServerAddressPicker"
                    Title="请选择服务器"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedIndexChanged="OnServerAddressSelected" />

                <Label
                    x:Name="ServerAddressStatusLabel"
                    FontSize="13"
                    LineBreakMode="CharacterWrap"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
            </VerticalStackLayout>

            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="10">
                <Button
                    x:Name="WebSocketTestButton"
                    Grid.Column="0"
                    Text="开始连接"
                    Style="{StaticResource ConnectActionButtonStyle}"
                    Clicked="OnWebSocketTestClicked"
                    HorizontalOptions="Fill" />

                <Button
                    x:Name="WebSocketDisconnectButton"
                    Grid.Column="1"
                    Text="断开连接"
                    Style="{StaticResource DisconnectActionButtonStyle}"
                    IsEnabled="False"
                    Clicked="OnWebSocketDisconnectClicked"
                    HorizontalOptions="Fill" />
            </Grid>

            <Button
                x:Name="DeleteLocalCacheButton"
                Text="删除本地缓存"
                BackgroundColor="#DC2626"
                Clicked="OnDeleteLocalCacheClicked"
                HorizontalOptions="Fill" />

            <Grid ColumnDefinitions="*,110">
                <Editor
                    Grid.Column="0"
                    x:Name="EditTestSendWsMsg"
                    Placeholder="这里填写消息内容"
                    Text="消息内容" />

                <Button
                    Grid.Column="1"
                    x:Name="BtnTestSendWsMsg"
                    Clicked="BtnTestSendWsMsg_Clicked"
                    Text="发送消息" />
            </Grid>
        </VerticalStackLayout>

        <Border
            Grid.Row="3"
            Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"
            StrokeThickness="1"
            Padding="12">

            <ScrollView
                x:Name="WebSocketResultScrollView"
                VerticalScrollBarVisibility="Always">

                <Label
                    x:Name="WebSocketTestResultLabel"
                    Text="尚未测试"
                    FontSize="14"
                    LineBreakMode="WordWrap"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
            </ScrollView>
        </Border>

        <Border
            x:Name="SettingsToast"
            Grid.RowSpan="4"
            Margin="0,0,0,24"
            Padding="16,10"
            IsVisible="False"
            Opacity="0"
            InputTransparent="True"
            HorizontalOptions="Center"
            VerticalOptions="End"
            StrokeThickness="0"
            BackgroundColor="#CC222222">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Label
                x:Name="SettingsToastLabel"
                FontSize="14"
                TextColor="White" />
        </Border>
    </Grid>
</ContentPage>
